{
  "name": "jp-labor-evidence-mcp",
  "version": "0.3.0",
  "description": "MCP server for Japanese labor and social insurance primary-source evidence",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "jp-labor-evidence-mcp": "dist/index.js"
  },
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "sync:indexes": "tsx scripts/sync-indexes.ts",
    "sync:indexes:full": "tsx scripts/sync-full-indexes.ts",
    "sync:indexes:incremental": "tsx scripts/sync-incremental-indexes.ts",
    "pack:dry-run": "npm pack --dry-run --cache ./.npm-pack-cache",
    "release:check": "npm test && npm run build && npm run pack:dry-run",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run release:check"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/finelagusaz/jp-labor-evidence-mcp"
  },
  "homepage": "https://github.com/finelagusaz/jp-labor-evidence-mcp#readme",
  "bugs": {
    "url": "https://github.com/finelagusaz/jp-labor-evidence-mcp/issues"
  },
  "keywords": [
    "mcp",
    "labor",
    "japan",
    "law",
    "e-gov",
    "mhlw",
    "sharoushi",
    "claude"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
